<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="AircraftDB"
			 connectionString="Server=(localdb)\MSSQLLocalDB;Database=AircraftDB;Integrated Security=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>
	<system.web>
		<compilation debug="true" targetFramework="4.7.2"/>
		<httpRuntime targetFramework="4.7.2"/>
	</system.web>
</configuration>